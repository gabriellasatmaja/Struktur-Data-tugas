#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

struct Node {
    string nama;
    vector<Node*> child;
    Node* parent;

    Node(string n) {
        nama = n;
        parent = NULL;
    }
};

Node* cariFolder(Node* root, string target) {
    if(root == NULL) return NULL;

    if(root->nama == target)
        return root;

    for(Node* anak : root->child) {
        Node* hasil =
            cariFolder(anak, target);

        if(hasil)
            return hasil;
    }

    return NULL;
}

void tambahFolder(Node* root,
                  string parentFolder,
                  string namaBaru)
{
    Node* parent =
        cariFolder(root, parentFolder);

    if(parent == NULL) {
        cout << "Folder induk tidak ditemukan\n";
        return;
    }

    Node* baru = new Node(namaBaru);
    baru->parent = parent;

    parent->child.push_back(baru);
}

void tampilDirektori(Node* root,
                     int level = 0)
{
    for(int i=0;i<level;i++)
        cout << "    ";

    cout << root->nama << endl;

    for(Node* anak : root->child)
        tampilDirektori(anak,
                        level + 1);
}

void preorder(Node* root)
{
    cout << root->nama << " ";

    for(Node* anak : root->child)
        preorder(anak);
}

void postorder(Node* root)
{
    for(Node* anak : root->child)
        postorder(anak);

    cout << root->nama << " ";
}

int hitungFolder(Node* root)
{
    int total = 1;

    for(Node* anak : root->child)
        total += hitungFolder(anak);

    return total;
}

void tampilPath(Node* node)
{
    vector<string> path;

    while(node)
    {
        path.push_back(node->nama);
        node = node->parent;
    }

    reverse(path.begin(),
            path.end());

    for(int i=0;i<path.size();i++)
    {
        cout << path[i];

        if(i != path.size()-1)
            cout << "/";
    }

    cout << endl;
}

int main()
{
    Node* root = new Node("Root");

    tambahFolder(root,"Root","Dokumen");
    tambahFolder(root,"Root","Gambar");
    tambahFolder(root,"Root","Musik");

    tambahFolder(root,"Dokumen","Kuliah");
    tambahFolder(root,"Dokumen","Tugas");

    cout << "Struktur Direktori:\n";
    tampilDirektori(root);

    cout << "\nPreorder:\n";
    preorder(root);

    cout << "\n\nPostorder:\n";
    postorder(root);

    cout << "\n\nJumlah Folder: ";
    cout << hitungFolder(root);

    cout << "\n\nPath Kuliah:\n";
    tampilPath(cariFolder(root,"Kuliah"));

    return 0;
}
